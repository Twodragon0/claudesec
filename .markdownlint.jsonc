{
  // Disable line length — tables and URLs often exceed 80 chars
  "MD013": false,
  // Allow inline HTML (badges, diagrams)
  "MD033": false,
  // Allow duplicate headings in different sections
  "MD024": { "siblings_only": true },
  // Disable link text style (too strict for reference links)
  "MD060": false,
  // Allow code fence style flexibility
  "MD040": false,
  // Allow multiple top-level headings (frontmatter + title)
  "MD025": false,
  // Emphasis style flexibility
  "MD036": false
}
