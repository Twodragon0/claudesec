#!/usr/bin/env bash
# ============================================================================
# ClaudeSec — One-command run: full scan + dashboard + serve
# ============================================================================
# Like oh-my-claudecode: zero config, one command.
#   ./run              → full scan, generate dashboard, serve at http://localhost:11777
#   ./run --no-serve   → full scan + dashboard only (no server)
#   ./run --quick      → quick scan (3 categories) + dashboard + serve
# ============================================================================

set -uo pipefail

CLAUDESEC_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$CLAUDESEC_DIR/scripts/run-full-dashboard.sh"

if [[ ! -f "$SCRIPT" ]]; then
  echo "ClaudeSec: run script not found at $SCRIPT" >&2
  exit 1
fi

exec "$SCRIPT" "$@"
