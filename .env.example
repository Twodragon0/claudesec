# ClaudeSec Asset Dashboard — Environment Variables (template)
#
# Usage: cp .env.example .env && fill in your values
# Never commit the populated .env — it is in .gitignore.
# Prefer a secrets manager (Vault, AWS Secrets Manager, 1Password CLI `op://`)
# over plaintext files for long-lived credentials.

# Google Sheets IDs (required for asset management)
ASSET_SHEET_ID=YOUR_ASSET_REGISTRY_SHEET_ID
AI_SHEET_ID=YOUR_AI_SUBSCRIPTION_SHEET_ID
COST_XLSX_ID=YOUR_SAAS_COST_XLSX_FILE_ID

# Datadog API (required for infrastructure monitoring + SIEM signals)
datadog_key_credential=YOUR_DATADOG_API_KEY
datadog_app_key_credential=YOUR_DATADOG_APP_KEY

# Zscaler ZIA API (required for ZPA/ZIA policy collection)
ZSCALER_API_KEY=YOUR_ZSCALER_API_KEY
ZSCALER_API_ADMIN=YOUR_ZSCALER_ADMIN_EMAIL
ZSCALER_API_PASSWORD=YOUR_ZSCALER_ADMIN_PASSWORD
ZSCALER_BASE_URL=https://admin.example.zscalerthree.net

# AWS Profiles (comma-separated, for infrastructure collection)
AWS_PROFILES=prod,dev

# Local cost file path (optional)
COST_XLSX_PATH=/absolute/path/to/software_license.xlsx

# Notion API (optional, for security audit history)
NOTION_API_KEY=YOUR_NOTION_INTEGRATION_TOKEN
NOTION_MCP_CACHE_PATH=
NOTION_MCP_SYNC_COMMAND=
