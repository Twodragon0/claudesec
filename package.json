{
  "name": "claudesec",
  "version": "0.7.1",
  "description": "DevSecOps toolkit for AI-assisted secure development — security scanner, ISMS dashboard, asset management",
  "bin": {
    "claudesec": "./bin/claudesec-cli.sh"
  },
  "scripts": {
    "scan": "./scanner/claudesec scan",
    "dashboard": "./scripts/run-dashboard-safe.sh",
    "setup": "./scripts/setup.sh",
    "quickstart": "docker compose -f docker-compose.quickstart.yml up",
    "test": "python3 -m pytest scanner/tests/ -v --tb=short"
  },
  "files": [
    "bin/",
    "scanner/",
    "scripts/",
    "!scripts/sync-cost-xlsx.py",
    "!scripts/update-license-active-accounts.py",
    "!scripts/update-pc-sheet.py",
    "!scripts/full-asset-sync.py",
    "!scripts/gsheet-auth.py",
    "!scripts/gsheet-auth-setup.py",
    "hooks/",
    "templates/",
    ".claude-plugin/",
    "Dockerfile",
    "Dockerfile.nginx",
    "docker-compose.yml",
    "docker-compose.quickstart.yml",
    "nginx/",
    ".env.example",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "devsecops", "security", "scanner", "isms", "isms-p",
    "prowler", "owasp", "claude-code", "dashboard",
    "compliance", "nist", "asset-management", "sast"
  ],
  "homepage": "https://github.com/Twodragon0/claudesec#readme",
  "bugs": "https://github.com/Twodragon0/claudesec/issues",
  "author": "Twodragon0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Twodragon0/claudesec.git"
  },
  "engines": {
    "node": ">=18"
  }
}
